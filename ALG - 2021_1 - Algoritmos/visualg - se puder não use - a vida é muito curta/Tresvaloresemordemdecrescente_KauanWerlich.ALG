Algoritmo "TrÍs valores em ordem decrescente"
//Kauan Henrique Werlich
//o programa ordena trÍs nķmeros inteiros e diferntes entre si.
//n„o funciona com dois ou trÍs nķmeros iguais
Var

 a,b,c :Inteiro

Inicio
 escreval ("Digite o primeiro nķmero:")
 leia (a)
 escreval ("Digite o segundo nķmero:")
 leia (b)
 escreval ("Digite o terceiro nķmero:")
 leia (c)
 
   se (a>b) e (b>c) entao
   escreval (a,b,c)
   senao
     se (a>c) e (c>b) entao
     escreval (a,c,b)
     senao
       se (a>b) e (c>a) entao
       escreval (c,a,b)
       senao
         se (b>c) e (c>a) entao
         escreval (b,c,a)
         senao
           se (b>a) e (a>c) entao
           escreval (b,a,c)
           senao
             se (c>b) e (b>a) entao
             escreval (c,b,a)
             senao
             escreval ("Erro na entrada dos nķmeros")
             fimse
           fimse
         fimse
       fimse
     fimse
   fimse
 
Fimalgoritmo